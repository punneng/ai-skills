# Notion Todo Environment Variables
#
# Requires NOTION_DATABASES with a `todo` entry.
# The skill resolves databases.todo to query and manage todo items.
#
# To obtain the database ID:
# 1. Open the database in Notion
# 2. Click "Share" → "Copy link"
# 3. Extract the ID from the URL (last segment after the final hyphen)

NOTION_DATABASES="todo:<your-todo-database-id>"
