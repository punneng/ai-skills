# Notion Todo Environment Variables
#
# Requires MCP_NOTION_DATA_SOURCES_IDS with comma-separated data source IDs.
# The first entry is used as the todo data source.
#
# To obtain the data source ID:
# 1. Open the data source in Notion
# 2. Click "Share" → "Copy link"
# 3. Extract the ID from the URL (last segment after the final hyphen)

MCP_NOTION_DATA_SOURCES_IDS="<your-todo-data-source-id>"
