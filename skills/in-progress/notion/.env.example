# Notion Integration Environment Variables
#
# Comma-separated name:id pairs.
# Skills reference destinations by name (e.g., pages.workspace, databases.todo).
#
# To obtain IDs:
# 1. Open the page/database in Notion
# 2. Click "Share" → "Copy link"
# 3. Extract the ID from the URL (last segment after the final hyphen)

NOTION_PAGES=""
NOTION_DATABASES="todo:<your-todo-database-id>"
